# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database
# Local: copy this to .env and point to your local Postgres.
# Production (e.g. Vercel): set DATABASE_URL in the host's environment to your production Postgres URL (Vercel Postgres, Neon, Supabase, etc.).
DATABASE_URL="postgresql://user:password@localhost:5432/ozmoji"

# Storage (S3 or Cloudflare R2 – same env; for R2 set S3_ENDPOINT to your R2 endpoint)
S3_BUCKET=your-bucket-name
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_ENDPOINT=  # Optional: for R2 use https://<account_id>.r2.cloudflarestorage.com
# Optional: public base URL for reads (e.g. R2 public bucket or CloudFront). If set, getPublicUrl() uses this.
STORAGE_PUBLIC_BASE_URL=

# AI Provider (OpenAI-compatible; uses chat completions for SVG generation)
AI_PROVIDER_API_KEY=your-api-key
# Optional: model override (default: gpt-4o-mini)
# AI_PROVIDER_MODEL=gpt-4o
